<Window
    x:Class="WinMLResNet.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinML EP Benchmarking Sample App">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="WinML EP Benchmarking Sample App"
                   FontSize="28" FontWeight="SemiBold" />

        <!-- Tabs -->
        <Pivot Grid.Row="1">

            <!-- Tab 1: Classification -->
            <PivotItem Header="Classification">
                <ScrollViewer x:Name="ClassificationScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel Spacing="16">

                        <!-- Controls Row -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="PickImageButton" Content="Pick an Image" Click="OnPickImage" />
                            <ComboBox x:Name="EpSelector" Width="320"
                                      PlaceholderText="Select Execution Provider"
                                      DisplayMemberPath="DisplayName" />
                            <Button x:Name="ClassifyButton" Content="Classify" Click="OnClassify" IsEnabled="False" />
                            <Button x:Name="RunAllButton" Content="Compare All EPs" Click="OnRunAll" IsEnabled="False" />
                            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.6" />
                        </StackPanel>

                        <!-- Image Preview + Predictions -->
                        <Grid x:Name="ImagePreviewGrid" ColumnSpacing="24" MinHeight="150">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="Gray"
                                    BorderThickness="1" CornerRadius="8" Padding="4">
                                <Image x:Name="PreviewImage" Stretch="Uniform" />
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Top 5 Predictions"
                                           FontSize="20" FontWeight="SemiBold" />
                                <ItemsControl x:Name="ResultsListView">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="12" Padding="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="1" Text="{Binding Score}"
                                                           Foreground="DodgerBlue" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <!-- EP Performance Comparison -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="EP Performance Comparison"
                                       FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />

                            <!-- Table Header -->
                            <Grid Padding="12,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontWeight="SemiBold" FontSize="12" Width="24" />
                                <TextBlock Grid.Column="1" Text="Execution Provider" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Grid.Column="2" Text="Mode" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Grid.Column="3" Text="Compile" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Grid.Column="4" Text="Preprocess" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Grid.Column="5" Text="Inference" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Grid.Column="6" Text="Total" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Grid.Column="7" Text="Top Prediction" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Grid.Column="8" Text="Confidence" FontWeight="SemiBold" FontSize="12" />
                            </Grid>

                            <!-- Metrics Rows -->
                            <ListView x:Name="MetricsListView" SelectionMode="None" MaxHeight="600">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,2" />
                                        <Setter Property="MinHeight" Value="28" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" Opacity="0.5" Width="24" />
                                            <TextBlock Grid.Column="1" Text="{Binding EpName}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            <TextBlock Grid.Column="2" Text="{Binding Mode}" FontSize="12" />
                                            <TextBlock Grid.Column="3" Text="{Binding CompileTime}" FontSize="12" />
                                            <TextBlock Grid.Column="4" Text="{Binding PreprocessTime}" FontSize="12" />
                                            <TextBlock Grid.Column="5" Text="{Binding InferenceTime}" Foreground="DodgerBlue" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Grid.Column="6" Text="{Binding TotalTime}" FontSize="12" />
                                            <TextBlock Grid.Column="7" Text="{Binding TopPrediction}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            <TextBlock Grid.Column="8" Text="{Binding TopConfidence}" Foreground="DodgerBlue" FontSize="12" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Tab 2: Model & Runtime Info -->
            <PivotItem Header="Model &amp; Runtime Info">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <Grid ColumnSpacing="24" RowSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Model Stats -->
                        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1"
                                CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="ONNX Model Info" FontSize="18" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="12" RowSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="File:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ModelFileName" FontSize="13" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Size:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ModelFileSize" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Producer:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ModelProducer" FontSize="13" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Version:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ModelVersion" FontSize="13" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Quantized:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ModelQuantized" FontSize="13" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Domain:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ModelDomain" FontSize="13" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Description:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="ModelDescription" FontSize="13" TextWrapping="Wrap" />
                                </Grid>

                                <TextBlock Text="Inputs / Outputs" FontWeight="SemiBold" FontSize="14" Margin="0,8,0,0" />
                                <ListView x:Name="TensorListView" SelectionMode="None" MaxHeight="160">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Display}" FontSize="12" FontFamily="Consolas" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <!-- Runtime Versions -->
                        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1"
                                CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Runtime Info" FontSize="18" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="12" RowSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Windows App SDK:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VersionWAS" FontSize="13" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="ONNX Runtime:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="VersionORT" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Windows ML:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="VersionWinML" FontSize="13" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text=".NET:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="VersionDotNet" FontSize="13" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="OS:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="VersionOS" FontSize="13" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Architecture:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="VersionArch" FontSize="13" />
                                </Grid>

                                <TextBlock Text="Deployment Info" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0" />
                                <Grid ColumnSpacing="12" RowSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Windows ML API:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DeployMlApi" FontSize="13" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="WASDK Deployment:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DeployWasMode" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="EP Acquisition:" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DeployEpMode" FontSize="13" TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </PivotItem>

            <!-- Tab 3: Glossary -->
            <PivotItem Header="Glossary">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel Spacing="16" MaxWidth="800">

                        <TextBlock Text="Benchmarking Columns" FontSize="20" FontWeight="SemiBold" />

                        <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Execution Provider" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                    Text="The hardware backend used to run the model. Examples: CPUExecutionProvider (CPU), DmlExecutionProvider (GPU via DirectML), OpenVINOExecutionProvider (Intel NPU/GPU/CPU). Each EP optimizes inference for its target hardware." />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Mode" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                    Text="Whether the model was run as-is (Uncompiled) or pre-compiled for the target EP (Compiled). Compiled mode uses OrtModelCompilationOptions to produce a hardware-optimized version of the ONNX model before inference, which can improve runtime performance at the cost of an upfront compilation step." />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Compile" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                    Text="Time spent compiling the ONNX model into a hardware-optimized format for the selected EP. This is a one-time cost — once compiled, the optimized model can be cached to disk. Shows '—' for uncompiled runs and 'cached' if the compiled session was already loaded in memory." />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Preprocess" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                    Text="Time spent preparing the image before it is fed to the model. This includes: loading the image file from disk, decoding it (JPEG/PNG), resizing it to 224x224 pixels (the input size ResNet-50 expects), converting pixel data from BGRA to RGB channels, and applying ImageNet normalization (subtracting per-channel means and dividing by standard deviations). This step runs on the CPU regardless of which EP is selected." />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Inference" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                    Text="Time spent running the ONNX model on the preprocessed input tensor. This is the core ML computation — the model evaluates all its layers/operators to produce output probabilities. This is the metric most affected by your choice of EP and hardware. Lower is better." />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Total" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                    Text="Wall-clock time from start to finish, including preprocessing, session creation (if first run for that EP), inference, and output processing. Note: Total may be larger than Preprocess + Inference because it includes session lookup/creation overhead and softmax post-processing." />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Top Prediction" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                    Text="The ImageNet class label with the highest confidence score after softmax. ResNet-50 classifies images into 1,000 categories (e.g., 'golden retriever', 'sports car'). All EPs should produce the same top prediction for a given image — if they differ, it may indicate a precision issue." />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Confidence" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                    Text="The softmax probability of the top prediction, expressed as a percentage. Higher means the model is more certain. Values near 100% indicate strong confidence; values below 20% suggest the model is unsure. Small differences across EPs are normal due to floating-point precision variations." />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Tab 4: About -->
            <PivotItem Header="About">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel Spacing="20" MaxWidth="800">

                        <StackPanel Spacing="4">
                            <TextBlock Text="About This App" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                Text="WinML EP Benchmarking Sample App is a sample/demo application built to exercise and benchmark the new Windows ML APIs (Microsoft.Windows.AI.MachineLearning) shipped with Windows App SDK. It classifies images using a ResNet-50 ONNX model and compares execution provider performance across CPU, GPU, and NPU hardware." />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Learn more at" FontSize="13" Opacity="0.85" VerticalAlignment="Center" />
                                <HyperlinkButton Content="aka.ms/winml" NavigateUri="https://aka.ms/winml"
                                                 FontSize="13" Opacity="0.85" Padding="0" Margin="4,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="." FontSize="13" Opacity="0.85" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Copilot Agent Skills" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                Text="This repo includes 7 GitHub Copilot agent skills (.github/skills/) distilled from lessons learned building this app. They help AI coding agents avoid common pitfalls when developing Windows ML applications:" />
                            <StackPanel Spacing="4" Margin="8,4,0,0">
                                <TextBlock FontSize="12" Opacity="0.8" Text="&#x2022; windows-ml-api — Use the correct New Windows ML API, not the old one" />
                                <TextBlock FontSize="12" Opacity="0.8" Text="&#x2022; windows-ml-project-setup — NuGet packages, csproj settings, native DLL deployment" />
                                <TextBlock FontSize="12" Opacity="0.8" Text="&#x2022; ort-init-order — ORT environment init must happen before any InferenceSession" />
                                <TextBlock FontSize="12" Opacity="0.8" Text="&#x2022; onnx-model-compilation — Which EPs support compilation and best practices" />
                                <TextBlock FontSize="12" Opacity="0.8" Text="&#x2022; windows-ml-ep-selection — Choosing between CPU, GPU, NPU, and AUTO EPs" />
                                <TextBlock FontSize="12" Opacity="0.8" Text="&#x2022; onnx-image-preprocessing — Image-to-tensor pipeline for vision models" />
                                <TextBlock FontSize="12" Opacity="0.8" Text="&#x2022; windows-ml-debugging — Version detection, deployment mode, common errors" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Third-Party Licenses &amp; Attributions" FontSize="18" FontWeight="SemiBold" />

                            <StackPanel Spacing="10" Margin="0,6,0,0">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="ResNet-50 v2 ONNX Model" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.8"
                                        Text="Source: ONNX Model Zoo (github.com/onnx/models)&#x0a;License: Apache License 2.0&#x0a;Copyright: The ONNX Authors" />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="ImageNet Labels" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.8"
                                        Text="The 1,000-class label set is derived from the ImageNet Large Scale Visual Recognition Challenge (ILSVRC). ImageNet is a project by Stanford Vision Lab, Princeton University, and others." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="ONNX Runtime" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.8"
                                        Text="Copyright (c) Microsoft Corporation&#x0a;License: MIT License&#x0a;Source: github.com/microsoft/onnxruntime" />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Windows App SDK / Windows ML" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.8"
                                        Text="Copyright (c) Microsoft Corporation&#x0a;License: MIT License&#x0a;Source: github.com/microsoft/WindowsAppSDK" />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="System.Numerics.Tensors" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.8"
                                        Text="Copyright (c) .NET Foundation and Contributors&#x0a;License: MIT License&#x0a;Source: github.com/dotnet/runtime" />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="DirectML" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.8"
                                        Text="Copyright (c) Microsoft Corporation&#x0a;License: MIT License&#x0a;Source: github.com/microsoft/DirectML" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="License" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                Text="This sample application is released under the MIT License. See the LICENSE file in the repository for full terms." />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="Local model inferencing powered by Windows ML &#x2014; learn more at"
                       FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
            <HyperlinkButton Content="aka.ms/winml" NavigateUri="https://aka.ms/winml"
                             FontSize="12" Opacity="0.5" Padding="0" Margin="4,0,0,0" VerticalAlignment="Center" />
            <TextBlock Text="." FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
